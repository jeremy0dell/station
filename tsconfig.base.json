{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@station/cli": ["apps/cli/src/index.ts"],
      "@station/cli/ingress": ["apps/cli/src/ingress/index.ts"],
      "@station/cli/internal": ["apps/cli/src/internal.ts"],
      "@station/observer": ["apps/observer/src/index.ts"],
      "@station/observer/internal": ["apps/observer/src/internal.ts"],
      "@station/client": ["packages/client/src/index.ts"],
      "@station/config": ["packages/config/src/index.ts"],
      "@station/contracts": ["packages/contracts/src/index.ts"],
      "@station/dashboard-core": ["packages/dashboard-core/src/index.ts"],
      "@station/dashboard-core/*": ["packages/dashboard-core/src/*"],
      "@station/claude": ["integrations/harness/claude/src/index.ts"],
      "@station/codex": ["integrations/harness/codex/src/index.ts"],
      "@station/cursor": ["integrations/harness/cursor/src/index.ts"],
      "@station/github-repository": ["integrations/repository/github/src/index.ts"],
      "@station/harness-shared": ["packages/harness-shared/src/index.ts"],
      "@station/opencode": ["integrations/harness/opencode/src/index.ts"],
      "@station/observability": ["packages/observability/src/index.ts"],
      "@station/pi": ["integrations/harness/pi/src/index.ts"],
      "@station/protocol": ["packages/protocol/src/index.ts"],
      "@station/runtime": ["packages/runtime/src/index.ts"],
      "@station/scripted-harness": ["integrations/harness/scripted/src/index.ts"],
      "@station/host": ["packages/station-host/src/index.ts"],
      "@station/testing": ["packages/testing/src/index.ts"],
      "@station/tmux": ["integrations/terminal/tmux/src/index.ts"],
      "@station/worktrunk": ["integrations/worktree/worktrunk/src/index.ts"]
    }
  }
}
